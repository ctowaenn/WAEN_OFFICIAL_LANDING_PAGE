# Copia a .env.local para `vercel dev` o rellena las mismas claves en Vercel → Settings → Environment Variables.
# No subas nunca .env con API key al repositorio.

BREVO_API_KEY=
# ID numérico de la lista en Brevo (Contacts → Lists → abrir lista → ID en URL o detalles). WAENN: 3
BREVO_LIST_ID=3
# Plantilla de email de doble opt-in (Marketing → Templates). Suele ser #1, no la "confirmación final".
BREVO_DOUBLE_OPTIN_TEMPLATE_ID=1
# Opcional si el servidor ya infiere el host: https://www.waenn.com/gracias
BREVO_REDIRECTION_URL=
